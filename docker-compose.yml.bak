version: "3.8"

services:
  db:
    image: mysql:8.0
    container_name: redsteel-db
    restart: unless-stopped
    environment:
      MYSQL_DATABASE: redsteel
      MYSQL_USER: redsteel_user
      MYSQL_PASSWORD: redsteel_pass
      MYSQL_ROOT_PASSWORD: root_pass
    volumes:
      - redsteel_db:/var/lib/mysql

  wordpress:
    image: wordpress:latest
    container_name: redsteel-wp
    restart: unless-stopped
    depends_on:
      - db
    environment:
      WORDPRESS_DB_HOST: redsteel-db:3306
      WORDPRESS_DB_USER: redsteel_user
      WORDPRESS_DB_PASSWORD: redsteel_pass
      WORDPRESS_DB_NAME: redsteel
      WORDPRESS_CONFIG_EXTRA: |
        define('FORCE_SSL_ADMIN', true);

        $proto = $_SERVER['HTTP_X_FORWARDED_PROTO'] ?? '';
        if ($proto === 'https') {
          $_SERVER['HTTPS'] = 'on';
        }

        define('WP_HOME', 'https://redsteel.com.ar');
        define('WP_SITEURL', 'https://redsteel.com.ar');

        define('WP_DEBUG', true);
        define('WP_DEBUG_LOG', true);
        define('WP_DEBUG_DISPLAY', false);


    volumes:
      - redsteel_wp:/var/www/html
    networks:
      - default
      - proxy_default

volumes:
  redsteel_db:
  redsteel_wp:

networks:
  proxy_default:
    external: true

